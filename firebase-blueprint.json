{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the inventory management system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The Firebase Auth UID." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "role": { "type": "string", "enum": ["admin", "staff"], "description": "The user's role." },
        "name": { "type": "string", "description": "The user's display name." },
        "active": { "type": "boolean", "description": "Whether the account is active." }
      },
      "required": ["uid", "email", "role", "name"]
    },
    "Product": {
      "title": "Product",
      "description": "An inventory item.",
      "type": "object",
      "properties": {
        "barcode": { "type": "string", "description": "Primary barcode for the product." },
        "barcodes": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "List of all barcodes associated with the product." 
        },
        "name": { "type": "string", "description": "Product name." },
        "quantityPerBox": { "type": "number", "description": "Standard quantity per box." },
        "currentStock": { "type": "number", "description": "Total units currently in stock." },
        "lastPurchasePrice": { "type": "number", "description": "Price of the most recent purchase." },
        "expiryDate": { "type": "string", "format": "date-time", "description": "Expiry date of the latest batch." },
        "lowStockThreshold": { "type": "number", "description": "Minimum units before low stock alert." },
        "expiryAlertThreshold": { "type": "number", "description": "Days before expiry to trigger alert." },
        "category": { "type": "string", "description": "Product category for organization." }
      },
      "required": ["barcode", "name", "currentStock"]
    },
    "Purchase": {
      "title": "Purchase",
      "description": "A record of a stock purchase.",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "ID of the product purchased." },
        "quantity": { "type": "number", "description": "Number of units purchased." },
        "price": { "type": "number", "description": "Purchase price per unit or total (as defined)." },
        "expiryDate": { "type": "string", "format": "date-time", "description": "Expiry date for this batch." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the purchase was recorded." },
        "recordedBy": { "type": "string", "description": "UID of the user who recorded the purchase." }
      },
      "required": ["productId", "quantity", "price", "expiryDate", "createdAt", "recordedBy"]
    },
    "SystemSettings": {
      "title": "System Settings",
      "description": "Global application settings.",
      "type": "object",
      "properties": {
        "notificationPhone": { "type": "string", "description": "Primary notification phone number." },
        "phoneNumber": { "type": "string", "description": "Secondary notification phone number." },
        "notificationEmail": { "type": "string", "description": "Email address for notifications." },
        "enableExpiryNotifications": { "type": "boolean", "description": "Whether to send expiry notifications." },
        "enableSmsNotifications": { "type": "boolean", "description": "Whether to send SMS notifications." },
        "enableEmailNotifications": { "type": "boolean", "description": "Whether to send Email notifications." },
        "enablePushNotifications": { "type": "boolean", "description": "Whether to send Push notifications." },
        "lastNotificationCheck": { "type": "string", "format": "date-time", "description": "Last time notifications were checked." }
      },
      "required": ["notificationPhone", "phoneNumber", "enableExpiryNotifications"]
    },
    "Task": {
      "title": "Task",
      "description": "A to-do item for the store.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Task title." },
        "description": { "type": "string", "description": "Task description." },
        "priority": { "type": "string", "enum": ["low", "medium", "high"], "description": "Task priority level." },
        "completed": { "type": "boolean", "description": "Whether the task is completed." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the task was created." },
        "dueDate": { "type": "string", "format": "date-time", "description": "Optional due date." },
        "createdBy": { "type": "string", "description": "UID of the creator." },
        "assignedTo": { "type": "string", "description": "Optional UID of the assigned user." }
      },
      "required": ["title", "priority", "completed", "createdAt", "createdBy"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product inventory records."
    },
    "/purchases/{purchaseId}": {
      "schema": "Purchase",
      "description": "Historical purchase records."
    },
    "/systemSettings/{settingsId}": {
      "schema": "SystemSettings",
      "description": "Global application settings."
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Store tasks and to-do items."
    }
  }
}
